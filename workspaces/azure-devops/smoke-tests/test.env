AZURE_DEVOPS_ORGANIZATION=smoke-test-org
AZURE_DEVOPS_PROJECT=smoke-test-value
AZURE_DEVOPS_TOKEN=dummy-smoke-test-secret
AZURE_DEVOPS_WIKI_IDENTIFIER=smoke-test-value
AZURE_ORG=smoke-test-org
AZURE_TOKEN=dummy-smoke-test-secret
