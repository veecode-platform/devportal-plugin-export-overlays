# Smoke-test placeholders for dynamic plugin config substitution.
# Values are non-production dummies for CI/local smoke runs only.
# Existing entries win over generated defaults; re-run to add missing keys.

DYNATRACE_ACCOUNT_URN=smoke-test-value
DYNATRACE_CLIENT_ID=smoke-client-id
DYNATRACE_CLIENT_SECRET=dummy-smoke-test-secret
DYNATRACE_NAME=smoke-test-value
DYNATRACE_TOKEN_URL=https://smoke-test.example.com/dynatrace_token_url
DYNATRACE_URL=https://smoke-test.example.com/dynatrace_url
