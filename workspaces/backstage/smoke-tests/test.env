# Smoke-test placeholders for dynamic plugin config substitution.
# Values are non-production dummies for CI/local smoke runs only.
# Existing entries win over generated defaults; re-run to add missing keys.

BITBUCKET_HOST=bitbucket.example.com
BITBUCKET_WORKSPACE=smoke-test-org
EMAIL_HOSTNAME=localhost
EMAIL_PASSWORD=dummy-smoke-test-secret
EMAIL_SENDER=smoke-test@example.com
EMAIL_USERNAME=dummyUser
GITHUB_ORG=smoke-test-org
GITHUB_URL=https://github.com
GITHUB_WEBHOOK_SECRET=smoke-webhook-secret
GITLAB_DISCOVERY_GROUP=smoke-test-org
GITLAB_HOST=gitlab.example.com
GITLAB_ORG_GROUP=smoke-test-org
K8S_CLUSTER_NAME=smoke-cluster
K8S_CLUSTER_TOKEN=dummy-smoke-test-secret
K8S_CLUSTER_URL=https://smoke-test.example.com/k8s_cluster_url
LDAP_BIND_DN=dc=smoke,dc=example,dc=com
LDAP_BIND_SECRET=dummy-ldap-secret
LDAP_GROUPS_DN=dc=smoke,dc=example,dc=com
LDAP_TARGET_URL=ldap://localhost:389
LDAP_USERS_DN=dc=smoke,dc=example,dc=com
MCP_TOKEN=dummy-smoke-test-secret
MICROSOFT_CLIENT_ID=smoke-client-id
MICROSOFT_CLIENT_SECRET=dummy-smoke-test-secret
MICROSOFT_TENANT_ID=11111111-1111-1111-1111-111111111111
