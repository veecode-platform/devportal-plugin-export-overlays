# Smoke-test placeholders for dynamic plugin config substitution.
# Values are non-production dummies for CI/local smoke runs only.
# Existing entries win over generated defaults; re-run to add missing keys.

PING_IDENTITY_API_BASE_URL=https://smoke-test.example.com/ping_identity_api_base_url
PING_IDENTITY_AUTH_BASE_URL=https://smoke-test.example.com/ping_identity_auth_base_url
PING_IDENTITY_CLIENT_ID=smoke-client-id
PING_IDENTITY_CLIENT_SECRET=dummy-smoke-test-secret
PING_IDENTITY_ENV_ID=smoke-id
