# Smoke-test placeholders for dynamic plugin config substitution.
# Values are non-production dummies for CI/local smoke runs only.
# Existing entries win over generated defaults; re-run to add missing keys.

KEYCLOAK_BASE_URL=https://smoke-test.example.com/keycloak_base_url
KEYCLOAK_CLIENT_ID=dummy-smoke-test-secret
KEYCLOAK_CLIENT_SECRET=dummy-smoke-test-secret
KEYCLOAK_LOGIN_REALM=dummy-smoke-test-secret
KEYCLOAK_REALM=dummy-smoke-test-secret
