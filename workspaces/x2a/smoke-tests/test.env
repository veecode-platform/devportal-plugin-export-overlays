# Smoke-test placeholders for dynamic plugin config substitution.
# Values are non-production dummies for CI/local smoke runs only.
# Existing entries win over generated defaults; re-run to add missing keys.

X2A_CALLBACK_BASE_URL=https://smoke-test.example.com/x2a_callback_base_url
X2A_CONVERTOR_IMAGE=quay.io/example/smoke-convertor
X2A_CONVERTOR_IMAGE_TAG=latest
X2A_KUBERNETES_NAMESPACE=smoke-test-namespace
