ARGOCD_INSTANCE2_URL=https://example_url
ARGOCD_PASSWORD=dummy-smoke-test-secret
ARGOCD_USERNAME=dummyUser
AWS_ACCESS_KEY_ID=AKIADUMMY000000
AWS_SECRET_ACCESS_KEY=dummyAwsSecretKey
